class Solution {
public:
    int pivotIndex(vector<int>& nums) {
        int prefixSum=0;
        int totalSum=0;
        for(int i: nums)
        totalSum +=i;
        for(int i=0;i<nums.size();i++){
            prefixSum += nums[i];
            int leftSum= prefixSum - nums[i];
            int rightSum=totalSum-prefixSum;
            if(leftSum == rightSum)
            return i;
        }
        return -1;
    
        
    }
    
};
