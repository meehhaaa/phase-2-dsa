class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int n= nums.size();
        map<int,int> m;
        
        for (int i : nums){
            m[i]++;
            if(m[i]>n/2)
            return i;
        }
        return -1;
        
    }
};
